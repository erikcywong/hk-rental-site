# Stripe Configuration
# Get these keys from https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (optional - for subscription mode)
# Create products in Stripe Dashboard -> Products -> Add Product
# Then copy the Price ID (starts with price_)
STRIPE_PRICE_BASIC=price_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret (for production)
# Set up webhook in Stripe Dashboard -> Developers -> Webhooks
# Endpoint URL: https://your-domain.vercel.app/api/webhook
# Events to listen: checkout.session.completed, invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Instructions:
# 1. Copy this file to `.env.local` for local development
# 2. For Vercel deployment, add these environment variables in:
#    Vercel Dashboard -> Settings -> Environment Variables
# 3. Never commit `.env.local` to Git (it's in .gitignore)
